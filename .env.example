# Database configuration for PostgreSQL
POSTGRES_DB=my_app_db
POSTGRES_USER=my_app_user
POSTGRES_PASSWORD=supersecretpassword
POSTGRES_PORT=5432
POSTGRES_CONTAINER_NAME=my_app-postgres

# Prisma — constructed from the values above
DATABASE_URL=postgresql://my_app_user:supersecretpassword@postgres:5432/my_app_db

# NestJS API
API_PORT=3000
API_CONTAINER_NAME=my_app_api

# Next.js Web App
WEB_PORT=3001
WEB_CONTAINER_NAME=my_app_web

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# JWT
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Cors
FRONTEND_URL=http://localhost:3001
